# Use global pnpm store instead of project-local store
# This allows sharing packages across git worktrees
store-dir=~/.local/share/pnpm/store

# Prevent downgrade of packages already in the lockfile
trust-policy=no-downgrade

# Only allow packages published at least 7 days ago (10080 minutes)
minimum-release-age=10080
minimum-release-age-exclude[]=next
minimum-release-age-exclude[]=@next/*
