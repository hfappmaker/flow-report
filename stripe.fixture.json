{
  "_meta": {
    "template_version": 0,
    "exclude_metadata": false
  },
  "fixtures": [
    {
      "name": "customer",
      "expected_error_type": "",
      "path": "/v1/customers",
      "method": "post",
      "params": {
        "email": "loadtest1@example.com",
        "metadata" : {
          "userId": "test-loadtest1"
        }
      }
    },
    {
      "name": "payment_method",
      "expected_error_type": "",
      "path": "/v1/payment_methods/pm_card_visa/attach",
      "method": "post",
      "params": {
        "customer": "${customer:id}"
      }
    },
    {
      "name": "checkout_session",
      "expected_error_type": "",
      "path": "/v1/checkout/sessions",
      "method": "post",
      "params": {
        "customer": "${customer:id}",
        "payment_method_types": ["card"],
        "line_items": [{
          "price": "{{env:STRIPE_PRICE_ID}}",
          "quantity": 1
        }],
        "mode": "subscription",
        "subscription_data": {
          "trial_period_days": 30
        },
        "success_url": "https://example.com/success",
        "cancel_url": "https://example.com/cancel"
      }
    },
    {
      "name": "subscription_create",
      "expected_error_type": "",
      "path": "/v1/subscriptions",
      "method": "post",
      "params": {
        "customer": "${customer:id}",
        "items": [{
          "price": "${STRIPE_PRICE_ID}"
        }],
        "trial_period_days": 30,
        "default_payment_method": "${payment_method:id}"
      }
    },
    {
      "name": "trial_end_simulation",
      "expected_error_type": "",
      "path": "/v1/subscriptions/${subscription_create:id}",
      "method": "post",
      "params": {
        "trial_end": "now"
      }
    },
    {
      "name": "first_invoice_payment",
      "expected_error_type": "",
      "path": "/v1/invoices/upcoming",
      "method": "get",
      "params": {
        "customer": "${customer:id}",
        "subscription": "${subscription_create:id}"
      }
    }
  ],
  "env": {
    "STRIPE_PRICE_ID": "required"
  }
}