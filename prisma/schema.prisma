generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum WorkReportStatus {
  DRAFT // 作成中
  SUBMITTED // 作成完了
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum ContractRateType {
  upperLower // 上下割
  middle // 中間割
  fixed // 固定精算
  hourlyRate // 時間単価
}

enum TaxInclusiveType {
  INCLUSIVE // 税込
  EXCLUSIVE // 税抜
}

enum TaxRoundingType {
  ROUND_DOWN // 切り捨て
  ROUND_UP   // 切り上げ  
  ROUND      // 四捨五入
}

enum SubscriptionStatus {
  TRIAL      // トライアル期間中
  ACTIVE     // 有料プラン利用中
  CANCELED   // キャンセル済み
}

enum TemplateType {
  WORK_REPORT // 作業報告書
  INVOICE     // 請求書
}

// ADMINは契約の作成、支払いの作成、Userの割り当てとUSERで出来ることが全て可能
// USERは契約の閲覧、WorkReportの作成が可能
model User {
  id                    String                 @id @default(cuid())
  name                  String?
  email                 String?                @unique
  emailVerified         DateTime?
  image                 String?
  password              String?
  role                  UserRole               @default(USER)
  accounts              Account[]
  isTwoFactorEnabled    Boolean                @default(false)
  twoFactorConfirmation TwoFactorConfirmation?
  contracts             Contract[]
  auditLogs             AuditLog[]
  EmailTemplate         EmailTemplate[]
  excelTemplates        ExcelTemplate[]
}


model Contract {
  id            String           @id @default(cuid())
  name          String
  startDate     DateTime
  endDate       DateTime
  
  // クライアント情報（契約時点のスナップショット）
  clientName         String
  clientContactName  String // 担当者名(作業報告書のメール宛先)
  clientEmail        String // 担当者メールアドレス(作業報告書のメール宛先)
  
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workReports   WorkReport[]
  unitPrice     Decimal? // 月単価
  settlementMin Decimal? // 精算幅下限
  settlementMax Decimal? // 精算幅上限
  rateType      ContractRateType @default(upperLower)
  upperRate     Decimal? // 超過時間単価
  lowerRate     Decimal? // 控除時間単価
  middleRate    Decimal? // 中間割の時間単価
  hourlyRate    Decimal? // 時間単価

  dailyWorkMinutes   Int? // 1日あたりの作業単位(分)
  monthlyWorkMinutes Int? // 1ヶ月あたりの作業単位(分)
  basicStartTime     DateTime? @db.Time // 基本開始時刻
  basicEndTime       DateTime? @db.Time // 基本終了時刻
  basicBreakDuration Int? // 基本休憩時間（分）
  basicMemo          String? // 基本作業内容

  closingDay Int? // 締め日(1～31)
  
  taxInclusiveType TaxInclusiveType @default(EXCLUSIVE) // 税込・税抜
  taxRoundingType TaxRoundingType @default(ROUND_DOWN) // 消費税端数処理
}

model WorkReport {
  id          String           @id @default(cuid())
  targetDate  DateTime         // YYYY-MM-01 形式で保存
  contract    Contract         @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId  String
  remarks     String?
  attendances Attendance[]
  status      WorkReportStatus @default(DRAFT)

  @@unique([targetDate, contractId])
}

model Attendance {
  id            String     @id @default(cuid())
  date          DateTime
  startTime     DateTime?  @db.Time // 時刻のみ（例：HH:mm:ss）, 入力がない場合は null
  endTime       DateTime?  @db.Time // 時刻のみ（例：HH:mm:ss）, 入力がない場合は null
  breakDuration Int?       // 休憩時間（分）
  memo          String?
  workReport    WorkReport @relation(fields: [workReportId], references: [id], onDelete: Cascade)
  workReportId  String

  @@unique([date, workReportId])
}

model EmailTemplate {
  id           String   @id @default(cuid())
  name         String   @unique // テンプレート識別子（"work-report-submission" など）
  subject      String // メール件名
  body         String // メール本文（HTMLやプレーンテキスト）
  createUserId String
  createUser   User     @relation(fields: [createUserId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorConfirmation {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model AuditLog {
  id            String      @id @default(cuid())
  tableName     String // 変更対象のテーブル名（例："User", "Contract", 等）
  recordId      String // 対象レコードのID
  action        AuditAction // 操作の種別
  // 変更内容の詳細を JSON 形式で格納（必要に応じて）
  changedFields Json?
  createdAt     DateTime    @default(now())
  // 操作を行ったユーザー（任意）
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
}

model StripeCustomer {
  id               String         @id @default(cuid())
  userId           String         @unique
  stripeCustomerId String         @unique
  created          DateTime
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Subscription {
  id                   String            @id @default(cuid())
  stripeCustomerId     String
  stripeSubscriptionId String            @unique
  status               SubscriptionStatus
  currentPeriodEnd     DateTime?         // 現在の請求期間の終了日時
  created              DateTime
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
}

model ExcelTemplate {
  id            String               @id @default(cuid())
  name          String               // テンプレート名
  type          TemplateType         @default(WORK_REPORT) // テンプレートの種類
  fileData      String               @db.Text // ExcelファイルのBase64エンコードデータ
  fileName      String               // 元のファイル名（表示用）
  sheetName     String?              // 出力するシート名（nullの場合は最初のシート）
  createUserId  String
  createUser    User                 @relation(fields: [createUserId], references: [id], onDelete: Cascade)
  fieldMappings ExcelTemplateField[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([name, createUserId, type])
}

model ExcelTemplateField {
  id            String        @id @default(cuid())
  templateId    String
  template      ExcelTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  namedRange    String        // Excelの名前付き範囲名
  valueTemplate String        // 値テンプレート（例: "${作業者名}様"）
  numFmt        String?       // 数値フォーマット（例: "[h]:mm"）
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([templateId, namedRange])
}
