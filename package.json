{
  "name": "work-time-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "dev:turbo": "rm -rf .next && next dev --turbopack",
    "dev:inspect": "rm -rf .next && NODE_OPTIONS='--inspect' next dev",
    "dev:test": "rm -rf .next && NODE_ENV=test next dev -p 5000",
    "build": "next build",
    "start": "prisma migrate deploy && next start -p 80",
    "lint": "next lint",
    "analyze": "ANALYZE=true next build",
    "postinstall": "prisma generate",
    "test:j": "jest",
    "test:p": "playwright test",
    "test:p:ui": "playwright test --ui",
    "test:p:debug": "playwright test --debug",
    "test:p:headed": "playwright test --headed",
    "seed:test-users": "npx tsx --env-file=.env scripts/seed-test-users.ts"
  },
