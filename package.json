{
  "name": "work-time-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "reset:dev": "pnpm exec dotenv -e .env.development.local -- pnpm exec prisma db push --force-reset && pnpm exec dotenv -e .env.development.local -- pnpm exec prisma db seed",
    "reset:preview": "pnpm exec dotenv -e .env.preview.local -- pnpm exec prisma db push --force-reset && pnpm exec dotenv -e .env.preview.local -- pnpm exec prisma db seed",
    "dev": "rm -rf .next && next dev",
    "dev:turbo": "rm -rf .next && next dev --turbopack",
    "dev:inspect": "rm -rf .next && NODE_OPTIONS='--inspect' next dev",
    "build": "next build",
    "start": "prisma migrate deploy && next start -p 80",
    "lint": "eslint --cache --cache-location .eslintcache \"src/**/*.{ts,tsx}\"",
    "analyze": "ANALYZE=true next build",
    "postinstall": "prisma generate",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:p": "playwright test",
    "test:p:ui": "playwright test --ui",
    "test:p:debug": "playwright test --debug",
    "test:p:headed": "playwright test --headed",
    "worktree:init": "bash scripts/worktree-init.sh",
    "worktree:list": "bash scripts/worktree-list.sh",
    "worktree:remove": "bash scripts/worktree-remove.sh"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@hookform/resolvers": "^5.2.2",
    "@mui/material": "^7.3.4",
    "@mui/styled-engine-sc": "^7.3.3",
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.0",
    "@prisma/extension-accelerate": "^3.0.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-form": "^0.1.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/themes": "^3.2.0",
    "@stripe/stripe-js": "^8.5.2",
    "@types/exceljs": "^1.3.2",
    "axios": "^1.13.1",
    "bcryptjs": "^3.0.3",
    "caniuse-lite": "^1.0.30001756",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "dayjs": "^1.11.19",
    "exceljs": "^4.4.0",
    "jotai": "^2.15.1",
    "lucide-react": "^0.554.0",
    "next": "^16.0.1",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.4",
    "ollama": "^0.6.2",
    "openai": "^6.9.1",
    "radix-ui": "^1.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.1",
    "react-icons": "^5.4.0",
    "resend": "^6.5.2",
